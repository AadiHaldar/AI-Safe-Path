# ============================================
# REQUIRED API KEYS FOR SAFEZONE
# ============================================

# GEMINI_API_KEY: Required for Gemini AI API calls
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# VITE_GOOGLE_MAPS_API_KEY: Required for Google Maps integration
# Get from: https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API, Directions API, Places API, Geocoding API
VITE_GOOGLE_MAPS_API_KEY="AIzaSyDyy-wSviHRgG4ygN7lYyhQQMWKi8uVbU8"

# ============================================
# FIREBASE CONFIGURATION (for real-time unsafe area reporting)
# Get from: https://console.firebase.google.com/
# ============================================
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_APP_ID"

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# APP_URL: The URL where this applet is hosted
# AI Studio automatically injects this at runtime with the Cloud Run service URL
APP_URL="MY_APP_URL"

# API TIMEOUTS AND LIMITS
VITE_API_TIMEOUT="30000"
VITE_CACHE_DURATION="3600000"
VITE_MAX_RETRIES="3"
